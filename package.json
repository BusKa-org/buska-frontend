{
  "name": "buska",
  "version": "0.1.1-beta",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "android": "npm run bridge && react-native run-android",
    "ios": "react-native run-ios",
    "web": "webpack serve --mode development --open",
    "build:web": "webpack --mode production",
    "build:android": "cd android && ./gradlew assembleRelease",
    "bridge": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:5000 tcp:5000",
    "clean": "cd android && ./gradlew clean && cd ..",
    "test": "jest",
    "lint": "eslint .",
    "pretypecheck": "npm run api:generate",
    "typecheck": "tsc --noEmit",
    "api:generate": "swagger2openapi ../buska-backend/docs/openapi.json -o ../buska-backend/docs/openapi3.json && openapi-typescript ../buska-backend/docs/openapi3.json --output src/types/openapi.ts"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/geolocation": "^3.2.1",
    "@react-native-firebase/app": "19.3.0",
    "@react-native-firebase/messaging": "19.3.0",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.10.4",
    "axios": "1.6.8",
    "expo-font": "^14.0.11",
    "leaflet": "^1.9.4",
    "leaflet-routing-machine": "^3.2.12",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-leaflet": "^4.2.1",
    "react-native": "^0.72.17",
    "react-native-config": "1.5.10",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-safe-area-context": "4.6.3",
    "react-native-screens": "3.22.0",
    "react-native-svg": "^13.8.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-webview": "13.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/preset-react": "^7.22.5",
    "@babel/runtime": "^7.20.0",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@tsconfig/react-native": "^3.0.0",
    "@types/react": "^18.0.24",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.2.1",
    "babel-loader": "^9.1.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-react-native-web": "^0.21.2",
    "css-loader": "^6.8.1",
    "dotenv-webpack": "^8.1.1",
    "eslint": "^8.19.0",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.2.1",
    "metro-react-native-babel-preset": "0.76.8",
    "openapi-typescript": "^7.13.0",
    "prettier": "^2.4.1",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "18.2.0",
    "style-loader": "^3.3.3",
    "swagger2openapi": "^7.0.8",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  },
  "engines": {
    "node": ">=18"
  }
}
