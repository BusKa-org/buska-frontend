{
    "extends": "@tsconfig/react-native/tsconfig.json",
    "compilerOptions": {
      "target": "ES2020",
      "module": "ESNext",
      "allowJs": true,
      "checkJs": false,
      "noEmit": true,
      "strict": false,
      "strictNullChecks": true,
      "skipLibCheck": true,
      "resolveJsonModule": true,
      "moduleResolution": "bundler",
      "baseUrl": ".",
      "paths": {
        "@/*": ["src/*"]
      },
      "types": ["react", "react-native", "jest"],
      "lib": ["esnext", "dom"]
    },
    "include": [
      "src",
      "App.tsx",
      "App.js",
      "index.web.tsx",
      "index.js",
      "*.d.ts"
    ],
    "exclude": [
      "node_modules",
      "android",
      "ios"
    ]
}