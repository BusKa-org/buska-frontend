<resources>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Prevents NullPointerException in ReactTextInputShadowNode when creating EditText.
             React Native's TextInput handles its own styling, so the Android background is unused. -->
        <item name="android:editTextBackground">@null</item>
    </style>
</resources>


